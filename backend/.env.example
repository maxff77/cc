# Backend configuration (copy to backend/.env — gitignored)
# asyncpg driver is mandatory for the async engine
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/cc

# --- Auth / session (Story 1.2) — all optional, sane defaults in config.py ---
# Cookie name for the opaque server-side session.
# SESSION_COOKIE_NAME=cc_session
# MUST be true in production (HTTPS via Caddy). Leave false for local http dev,
# otherwise the browser silently drops the cookie and login won't stick.
COOKIE_SECURE=false
# Session lifetime in days (also the cookie max-age).
# SESSION_TTL_DAYS=14
# Trust the leftmost X-Forwarded-For for the client IP. Only enable behind a
# trusted proxy (Caddy) that sets it — otherwise it's client-spoofable and
# defeats the login throttle. Leave false in local dev.
# TRUST_FORWARDED_FOR=false
# Login throttle: reject past THROTTLE_MAX_ATTEMPTS failures per
# (email, ip) within THROTTLE_WINDOW_SECONDS.
# THROTTLE_MAX_ATTEMPTS=5
# THROTTLE_WINDOW_SECONDS=900

# --- Owner bootstrap (Story 1.3) -------------------------------------------
# Read ONLY by scripts/bootstrap_owner.py (run-once owner seed), never loaded
# into app/config.py Settings — owner credentials stay out of the app process.
# Set them when running the bootstrap on deploy (Story 1.7), then unset.
# OWNER_EMAIL=owner@cc.local
# OWNER_PASSWORD=change-me-strong

# --- Production (Story 1.7) -------------------------------------------------
# Values for backend/.env ON THE VPS (real credentials — never committed).
# COOKIE_SECURE MUST be true in production: HTTPS via Caddy; browsers drop
# Secure cookies over plain http (the exact inverse of local dev above).
# COOKIE_SECURE=true
# Safe ONLY behind Caddy, which sets X-Forwarded-For when reverse-proxying.
# Without it every login arrives as 127.0.0.1 and the per-(email, IP)
# throttle degrades to per-email. Keep false anywhere without that proxy.
# TRUST_FORWARDED_FOR=true
# Prod database: the VPS Postgres role + db `cc` (runbook step 5).
# DATABASE_URL=postgresql+asyncpg://cc:***@127.0.0.1:5432/cc
# Telethon credentials — read ONLY by scripts/telegram_auth.py (Story 2.2
# promotes them into the app). Get them at https://my.telegram.org/apps.
# TELEGRAM_API_ID=123456
# TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef
# Session file location: outside the repo and the web root, mode 600.
# TELEGRAM_SESSION_PATH=/var/lib/cc/anon.session
