# Backend configuration (copy to backend/.env — gitignored)
# asyncpg driver is mandatory for the async engine
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/cc

# --- Auth / session (Story 1.2) — all optional, sane defaults in config.py ---
# Cookie name for the opaque server-side session.
# SESSION_COOKIE_NAME=cc_session
# MUST be true in production (HTTPS via Caddy). Leave false for local http dev,
# otherwise the browser silently drops the cookie and login won't stick.
COOKIE_SECURE=false
# Session lifetime in days (also the cookie max-age).
# SESSION_TTL_DAYS=14
# Trust the leftmost X-Forwarded-For for the client IP. Only enable behind a
# trusted proxy (Caddy) that sets it — otherwise it's client-spoofable and
# defeats the login throttle. Leave false in local dev.
# TRUST_FORWARDED_FOR=false
# Login throttle: reject past THROTTLE_MAX_ATTEMPTS failures per
# (email, ip) within THROTTLE_WINDOW_SECONDS.
# THROTTLE_MAX_ATTEMPTS=5
# THROTTLE_WINDOW_SECONDS=900
